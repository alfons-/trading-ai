# Variables de entorno (nunca subir claves)
.env
.env.local
*.env

# Logs de ejecución
data/execution_logs/
data/paper_logs/
logs/

# Logs y temporales
*.log
tmp/
temp/

# Configs de producción (cada Mac tiene el suyo)
configs/execution.prod.yaml
configs/*.local.yaml

# launchd (los .plist instalados en ~/Library/LaunchAgents/ no están en el repo;
