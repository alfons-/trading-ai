# Bybit API Keys
# ───────────────────────────────────────────────────────
# Testnet: https://testnet.bybit.com → API Management
# Mainnet: https://www.bybit.com → API Management
#
# IMPORTANTE: nunca subas este archivo (.env) a git.
#             Solo .env.example es seguro para versionar.

BYBIT_API_KEY=tu_api_key_aqui
BYBIT_API_SECRET=tu_api_secret_aqui

# Email notifications (optional)
# ───────────────────────────────────────────────────────
# Para Gmail usa una App Password: https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAILS=alice@example.com,bob@example.com
